
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Unique Training Center</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/UniqueClassesSite.styles.css" asp-append-version="true" />

    <style>
        html, body {
            height: auto !important; /* उंची लॉक होऊ नये म्हणून */
            min-height: 100%;
            overflow-y: auto !important; /* स्क्रोलिंग चालू करण्यासाठी */
        }

        .main-container {
            padding-bottom: 60px; /* फुटरसाठी जागा */
        }

        footer {
            position: relative; /* फिक्स्ड असल्यास स्क्रोलिंगला त्रास होतो, म्हणून रिलेटिव्ह ठेवले आहे */
            bottom: 0;
            width: 100%;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-primary border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">युनिक ट्रेनिंग सेंटर</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Index">होम</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-area="" asp-controller="Home" asp-action="Contactus">संपर्क</a>
                        </li>   
                        <li class="nav-item">
                            <a class="nav-link text-white" asp-controller="Account" asp-action="Login">लॉगिन</a>
                        </li>
                        <li class="nav-item">
                            <div id="google_translate_element"></div>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Attendance" asp-action="TakeAttendance">
                                📅 रोजची हजेरी (Attendance)
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Attendance" asp-action="StudentList">
                                👥 विद्यार्थी यादी (Student List)
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Attendance" asp-action="AttendanceHistory">
                                📊 हजेरी रिपोर्ट (Attendance History)
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-controller="Attendance" asp-action="DailyReport">
                                📊 डेली रिपोर्ट (Daily Report)
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container main-container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted bg-light py-3">
        <div class="container text-center">
            &copy; 2026 - <b>बापट हॉस्पिटलच्या वरती, मारुती मंदिराजवळ, विटा</b>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>