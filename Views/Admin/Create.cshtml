@model UniqueClassesSite.Models.Course
@{
    Layout = "_AdminLayout";
}
<div class="container mt-5">
    <h2>नवीन कोर्स जोडा</h2>
    <hr />
    <!-- महत्त्वाचे: enctype जोडायला विसरू नका -->
    <form asp-action="Create" method="post" enctype="multipart/form-data">

        <div class="form-group mb-3">
            <label>कोर्सचे नाव</label>
            <input asp-for="CourseName" class="form-control" placeholder="कोर्सचे नाव टाका" required />
            <span asp-validation-for="CourseName" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label>माहिती (Description)</label>
            <input asp-for="Description" class="form-control" placeholder="माहिती टाका" required />
            <span asp-validation-for="Description" class="text-danger"></span>
            
        </div>

        <!-- १. पोस्टर अपलोड करण्यासाठी -->
        <div class="form-group mb-3">
            <label>कोर्स पोस्टर (Image)</label>
            <input type="file" name="posterFile" class="form-control" accept="image/*" />
            <small class="text-muted">केवळ फोटो (JPG, PNG) निवडा.</small>
        </div>

        <!-- २. व्हिडिओ अपलोड करण्यासाठी -->
        <div class="form-group mb-3">
            <label>कोर्स व्हिडिओ (Video)</label>
            <input type="file" name="videoFile" class="form-control" accept="video/*" />
            <small class="text-muted">केवळ व्हिडिओ (MP4) निवडा.</small>
        </div>

        <div class="row">
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>कालावधी</label>
                    <input asp-for="Duration" class="form-control" placeholder="उदा. ३ महिने" />
                </div>
            </div>
            <div class="col-md-6">
                <div class="form-group mb-3">
                    <label>फीस</label>
                    <input asp-for="Fees" class="form-control" />
                </div>
            </div>
        </div>

        <div class="mt-3">
            <button type="submit" class="btn btn-success">कोर्स सेव्ह करा</button>
            <a asp-action="Index" class="btn btn-secondary">मागे जा</a>
        </div>
    </form>
</div>