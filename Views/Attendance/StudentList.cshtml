@model IEnumerable<UniqueClassesSite.Models.Student>

<div class="container mt-4" style="max-width: 850px; font-family: Arial, sans-serif;">
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center p-3">
            <h4 class="mb-0">👨‍🎓 एकूण विद्यार्थी यादी (All Students List)</h4>
            <a asp-action="TakeAttendance" class="btn btn-light fw-bold text-primary shadow-sm">
                📅 आजची हजेरी घ्या
            </a>
            <a asp-action="AddStudent" class="btn btn-warning fw-bold text-dark me-2">
                ➕ नवीन विद्यार्थी जोडा
            </a>
        </div>

        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-warning text-center fw-bold">
                    डेटाबेसमध्ये सध्या एकही विद्यार्थी उपलब्ध नाही. कृपया आधी विद्यार्थी ॲड करा!
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 15%; text-align: center;">ID</th>
                                <th style="width: 50%;">विद्यार्थ्याचे पूर्ण नाव</th>
                                <th style="width: 35%;">कोर्सचे नाव (Course Name)</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var student in Model)
                            {
                                <tr>
                                    <td align="center" class="fw-bold text-secondary">@student.StudentId</td>
                                    <td class="fw-bold text-dark">@student.StudentName</td>
                                    <td>
                                        @if (student.CourseName.Contains("Robotics"))
                                        {
                                            <span class="badge bg-warning text-dark fs-6">@student.CourseName</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-info text-dark fs-6">@student.CourseName</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>